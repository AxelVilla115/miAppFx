<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane hgap="10" vgap="12" xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.miappfx.FormularioController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Row 1 -->
    <Label text="Nombre: "
           GridPane.rowIndex="0"
           GridPane.columnIndex="0"
    />

    <TextField fx:id="NombreField"
               GridPane.rowIndex="0"
               GridPane.columnIndex="1"
    />
    <!-- Row 1 -->

    <!-- Row 2 -->
    <Label text="Email: "
        GridPane.rowIndex="1"
        GridPane.columnIndex="0"
    />
    <TextField fx:id="EmailField"
               GridPane.rowIndex="1"
               GridPane.columnIndex="1"
    />
    <!-- Row 2 -->

    <!-- Row 3 -->
    <Button text="Enviar"
            onAction="#handleEnviar"
            GridPane.rowIndex="2"
            GridPane.columnIndex="1"
    />
    <!-- Row 3 -->

</GridPane>