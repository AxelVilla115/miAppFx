<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.project.miappfx.TarjetaController"
            prefHeight="400.0" prefWidth="600.0">
            <top>
                <HBox alignment="CENTER" style="-fx-background-color: #0D2A52;">
                    <padding>
                        <Insets top="20" bottom="20"/>
                    </padding>
                    <children>
                        <Label text="MI TARJETA JAVAFX"
                               style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>
            </top>
            <center>
                <VBox alignment="CENTER_LEFT" spacing="10">
                    <padding>
                        <Insets left="40" right="40"/>
                    </padding>
                    <children>
                        <Label text="Nombre: [Tu Nombre]" style="-fx-font-size: 16px;"/>
                        <Label text="Carrera: TI e Innovación Digital" style="-fx-font-size: 16px;"/>
                        <Label text="Matrícula: 202XXXXX" style="-fx-font-size: 16px;"/>
                    </children>
                </VBox>
            </center>
            <bottom>
                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <padding>
                        <Insets top="15" bottom="15" right="20"/>
                    </padding>
                    <children>
                        <Button text="Más Información" />
                        <Button text="Cerrar" style="-fx-background-color: #e11d48; -fx-text-fill: white;"/>
                    </children>
                </HBox>
            </bottom>
</BorderPane>
